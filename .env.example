# Copy this file to .env and set real values.
# Do not commit .env to source control.

# Django core
SECRET_KEY=CHANGE_ME_use_a_long_random_string
#Set False to minic prodution or test, while True for function or UI development
DEBUG=False
# Comma-separated list of allowed hostnames/IPs (e.g. yourdomain.com,your.vm.ip)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=beihoo_db
DB_USER=beihoo_user
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432

# Locust load test users
LOCUST_ADMIN_USERNAME=loadtest_admin
LOCUST_DOCTOR_USERNAME=loadtest_doctor
LOCUST_CASE_MANAGER_USERNAME=loadtest_case_manager
LOCUST_CAREGIVER_USERNAME=loadtest_caregiver
LOCUST_TEST_PASSWORD=test1234

# Load-test lockdown activation control
LOADTEST_LOCKDOWN_ENABLED=False
LOADTEST_USERNAME_PREFIX=loadtest_
LOADTEST_ALLOWED_ROLES=admin,doctor,case_manager,caregiver

LOCUST_PATIENT_ID=1
LOCUST_ASSESSMENT_TEMPLATE_ID=1
